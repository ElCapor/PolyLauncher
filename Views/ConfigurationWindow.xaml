<Window x:Class="PolyLauncher.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PolyLauncher - Configuration" 
        Height="600" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1E1E1E">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C97EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="ModernLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="PolyLauncher Configuration" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       Margin="0,0,0,20"/>

            <GroupBox Header="Modding Features" 
                      Foreground="White" 
                      BorderBrush="#3F3F46"
                      Margin="0,10">
                <StackPanel Margin="10">
                    <CheckBox Content="Enable HWID Spoofer" 
                              IsChecked="{Binding EnableHwidSpoofer}"
                              Style="{StaticResource ModernCheckBox}"/>
                    <CheckBox Content="Auto-Start Executor" 
                              IsChecked="{Binding AutoStartExecutor}"
                              Style="{StaticResource ModernCheckBox}"/>
                    <CheckBox Content="Allow Multi-Client" 
                              IsChecked="{Binding AllowMulticlient}"
                              Style="{StaticResource ModernCheckBox}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Launch Settings" 
                      Foreground="White" 
                      BorderBrush="#3F3F46"
                      Margin="0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Launch Duration (seconds):" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding CustomLaunchDuration, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="100"
                                 Style="{StaticResource ModernTextBox}"/>
                        <TextBlock Text="(1-60 seconds)" 
                                   Foreground="#808080" 
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Visual Customization" 
                      Foreground="White" 
                      BorderBrush="#3F3F46"
                      Margin="0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Loading Text:" 
                               Style="{StaticResource ModernLabel}"/>
                    <TextBox Text="{Binding LoadingText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"/>

                    <TextBlock Text="Background Color (Hex):" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="150"
                                 Style="{StaticResource ModernTextBox}"/>
                        <Border Width="30" 
                                Height="30" 
                                Margin="10,0,0,0"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                Background="{Binding BackgroundBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Loading Bar Color (Hex):" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding LoadingBarColor, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="150"
                                 Style="{StaticResource ModernTextBox}"/>
                        <Border Width="30" 
                                Height="30" 
                                Margin="10,0,0,0"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                Background="{Binding LoadingBarBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Text Color (Hex):" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="150"
                                 Style="{StaticResource ModernTextBox}"/>
                        <Border Width="30" 
                                Height="30" 
                                Margin="10,0,0,0"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                Background="{Binding TextBrush}"/>
                    </StackPanel>

                    <TextBlock Text="Custom Loading Icon:" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding CustomLoadingIcon, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="300"
                                 IsReadOnly="True"
                                 Style="{StaticResource ModernTextBox}"/>
                        <Button Content="Browse..." 
                                Command="{Binding BrowseIconCommand}"
                                Style="{StaticResource ModernButton}"
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Installation" 
                      Foreground="White" 
                      BorderBrush="#3F3F46"
                      Margin="0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Installation Path:" 
                               Style="{StaticResource ModernLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="300"
                                 Style="{StaticResource ModernTextBox}"/>
                        <Button Content="Browse..." 
                                Command="{Binding BrowseInstallPathCommand}"
                                Style="{StaticResource ModernButton}"
                                Margin="10,0,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Install to Path" 
                                Command="{Binding InstallCommand}"
                                Style="{StaticResource ModernButton}"
                                Margin="0,0,10,0"/>
                        <Button Content="Uninstall PolyLauncher" 
                                Command="{Binding UninstallCommand}"
                                Style="{StaticResource ModernButton}"
                                Background="#D13438"/>
                    </StackPanel>
                    
                    <TextBlock Text="PolyLauncher is currently installed." 
                               Foreground="#00FF00" 
                               Margin="0,5,0,0"
                               Visibility="{Binding IsInstalled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="System" 
                      Foreground="White" 
                      BorderBrush="#3F3F46"
                      Margin="0,10">
                <StackPanel Margin="10">
                    <Button Content="Register Protocol Handler (polytoria://)" 
                            Command="{Binding RegisterProtocolCommand}"
                            Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Left"
                            Margin="0,5"/>
                    <Button Content="Unregister Protocol Handler" 
                            Command="{Binding UnregisterProtocolCommand}"
                            Style="{StaticResource ModernButton}"
                            Background="#D13438"
                            HorizontalAlignment="Left"
                            Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20">
                <Button Content="Save Settings" 
                        Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource ModernButton}"
                        Margin="5"/>
                <Button Content="Save &amp; Restart" 
                        Command="{Binding SaveAndRestartCommand}"
                        Style="{StaticResource ModernButton}"
                        Background="#007ACC"
                        Margin="5"/>
                <Button Content="Reset to Defaults" 
                        Command="{Binding ResetToDefaultsCommand}"
                        Style="{StaticResource ModernButton}"
                        Background="#D13438"
                        Margin="5"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
