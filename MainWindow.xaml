<Window x:Class="PolyLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PolyLauncher"
        mc:Ignorable="d"
        Title="PolyLauncher" 
        Height="300" 
        Width="600"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4F4F56"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{Binding LoadingBarBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E1E1E"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="{Binding BackgroundBrush}" 
            CornerRadius="10"
            BorderBrush="#3F3F46"
            BorderThickness="1">
        <Grid>
            <!-- Configuration View -->
            <Grid Visibility="{Binding ShowConfiguration, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="PolyLauncher" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="{Binding TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    
                    <TextBlock Text="First time setup required" 
                               FontSize="16" 
                               Foreground="{Binding TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <Button Content="Configure Launcher" 
                            Click="ConfigureButton_Click"
                            Style="{StaticResource ModernButton}"
                            Width="200"
                            Margin="0,5"/>
                    
                    <Button Content="Exit" 
                            Click="ExitButton_Click"
                            Style="{StaticResource ModernButton}"
                            Width="200"
                            Margin="0,5"/>
                </StackPanel>
            </Grid>

            <!-- Loading View -->
            <Grid Visibility="{Binding ShowLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" Margin="30,15">
                    <!-- Custom Icon or Default -->
                    <Viewbox Width="70" Height="70" Margin="0,0,0,15">
                        <Grid>
                            <!-- Default Spinner -->
                            <Grid x:Name="DefaultSpinner">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomIconPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CustomIconPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Ellipse Fill="{Binding LoadingBarBrush}" 
                                         Width="80" 
                                         Height="80"
                                         x:Name="LoadingSpinner">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform CenterX="40" CenterY="40"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                                                   From="0" To="360" Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Fill="{Binding BackgroundBrush}" 
                                         Width="60" 
                                         Height="60"
                                         Margin="10"/>
                            </Grid>

                            <!-- Custom Icon Image -->
                            <Image Source="{Binding CustomIconPath}" 
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Height" Value="32"/>
                                        <Setter Property="Width" Value="32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomIconPath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CustomIconPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Viewbox>

                    <!-- Loading Text -->
                    <TextBlock Text="{Binding LoadingText}" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="{Binding TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <!-- Countdown Text -->
                    <TextBlock HorizontalAlignment="Center"
                               Foreground="{Binding TextBrush}"
                               FontSize="13"
                               Opacity="0.8"
                               Margin="0,0,0,15">
                        <Run Text="Starting in "/>
                        <Run Text="{Binding CountdownSeconds, Mode=OneWay}"/>
                        <Run Text=" seconds..."/>
                    </TextBlock>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               FontSize="13" 
                               Foreground="{Binding TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               Height="18"
                               TextAlignment="Center"/>

                    <!-- Progress Bar -->
                    <Grid Margin="20,0,20,20">
                        <ProgressBar Value="{Binding ProgressValue}" 
                                     Height="12" 
                                     Background="#2D2D30"
                                     Foreground="{Binding LoadingBarBrush}"
                                     BorderThickness="0">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Grid x:Name="TemplateRoot">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"/>
                                        <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="6" Background="{TemplateBinding Foreground}"/>
                                    </Grid>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </Grid>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <Button Content="Start Now" 
                                Width="130"
                                Height="36"
                                Command="{Binding StartImmediatelyCommand}"
                                Style="{StaticResource ModernButton}"
                                Margin="10,0"/>
                        <Button Content="Configure" 
                                Width="130"
                                Height="36"
                                Command="{Binding ConfigureCommand}"
                                Style="{StaticResource ModernButton}"
                                Margin="10,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
